# Copy to .env (gitignored) and fill in. The agent reads these via os.getenv.
# CoinMarketCap Pro API key — get a free Basic key at https://coinmarketcap.com/api
CMC_API_KEY=

# TWAK wallet signing uses the OS keychain by default (set up via `npx twak setup`).
# Only set this if you are NOT using the keychain (e.g. a Linux host):
# TWAK_WALLET_PASSWORD=
